								{
									"_type": "UMLNoteView",
									"_id": "AAAAAAGdKlT5nabCN7Q=",
									"_parent": {
										"$ref": "AAAAAAGdKjrtDaRJVIg="
									},
									"font": "Arial;13;0",
									"left": 982,
									"top": 87,
									"width": 281,
									"height": 137,
									"text": "Etape 2 : Scénario d'Erreur\nUn Champs obligatoire est vide\n2.1 Afficher un message d'erreur à l'utilisateur\n2.2 Demander Correction à l'utilisateur\n2.3 L'utilisateur corrige les champs\nDans le scénario nominal tout les champs sont remplis"
								},
								{
									"_type": "UMLNoteView",
									"_id": "AAAAAAGdKlT5nabDyRI=",
									"_parent": {
										"$ref": "AAAAAAGdKjrtDaRJVIg="
									},
									"font": "Arial;13;0",
									"left": 982,
									"top": 239,
									"width": 281,
									"height": 139,
									"text": "Etape 3 : Scénario d'Erreur\nLe format des données est erroné\n3.1 Afficher un message d'erreur à l'utilisateur\n3.2 Demander Correction à l'utilisateur\n3.3 L'utilisateur corrige les champs\nDans le scénario nominal le format des données correspond au format de données attendus"
								},
								{
									"_type": "UMLNoteView",
									"_id": "AAAAAAGdKlWDFqbRQOU=",
									"_parent": {
										"$ref": "AAAAAAGdKjrtDaRJVIg="
									},
									"font": "Arial;13;0",
									"left": 984,
									"top": 424,
									"width": 281,
									"height": 137,
									"text": "Etape 7 : Scénario Alternatif\nUn Champs obligatoire est vide\n7.1 Afficher un message d'erreur à l'utilisateur\n7.2 Demander Correction à l'utilisateur\n7.3 L'utilisateur corrige les champs\nDans le scénario nominal tout les champs sont remplis"
								},
								{
									"_type": "UMLNoteView",
									"_id": "AAAAAAGdKlWDFqbS0jI=",
									"_parent": {
										"$ref": "AAAAAAGdKjrtDaRJVIg="
									},
									"font": "Arial;13;0",
									"left": 984,
									"top": 592,
									"width": 281,
									"height": 139,
									"text": "Etape 8 : Scénario Alternatif\nLe format des données est erroné\n8.1 Afficher un message d'erreur à l'utilisateur\n8.2 Demander Correction à l'utilisateur\n8.3 L'utilisateur corrige les champs\nDans le scénario nominal le format des données correspond au format de données attendus"
								},
								{
									"_type": "UMLNoteView",
									"_id": "AAAAAAGdKlcKhqbeNxw=",
									"_parent": {
										"$ref": "AAAAAAGdKjrtDaRJVIg="
									},
									"font": "Arial;13;0",
									"left": 1056,
									"top": 752,
									"width": 281,
									"height": 139,
									"text": "Etape 10 : Scénario d'Erreur\nL'utilisateur a annulé l'annulation\n10.1 Afficher un message de confirmation de l'annulation de l'annulation à l'utilisateur\n10.2. Arrêter le scénario\nDans le scénario nominal l'utilisateur confirme l'annulation de la commande"
								},
								{
									"_type": "UMLNoteView",
									"_id": "AAAAAAGdKliZvKbnfLw=",
									"_parent": {
										"$ref": "AAAAAAGdKjrtDaRJVIg="
									},
									"font": "Arial;13;0",
									"left": 992,
									"top": 912,
									"width": 281,
									"height": 139,
									"text": "Etape 11 : Scénario d'Erreur\nLa fonction de demande de remboursement acompte ne donne pas de réponse\n11.1 Afficher un message d'erreur\n11.2. Arrêter le scénario\nDans le scénario nominal la fonction renvoie une réponse"
								},
								{
									"_type": "UMLNoteView",
									"_id": "AAAAAAGdKlnWqqbwCRM=",
									"_parent": {
										"$ref": "AAAAAAGdKjrtDaRJVIg="
									},
									"font": "Arial;13;0",
									"left": 992,
									"top": 1080,
									"width": 281,
									"height": 139,
									"text": "Etape 12 : Scénario d'Erreur\nLa fonction de demande de remboursement acompte a envoyé une réponse mais n'a pas pu confirmer le remboursement de l'acompte\n11.1 Afficher un message d'erreur\n11.2. Arrêter le scénario\nDans le scénario nominal la fonction confirme le remboursement de l'acompte par l'artiste"
								},
								{
									"_type": "UMLNoteView",
									"_id": "AAAAAAGdKlq1MKb39Vo=",
									"_parent": {
										"$ref": "AAAAAAGdKjrtDaRJVIg="
									},
									"font": "Arial;13;0",
									"left": 992,
									"top": 1232,
									"width": 281,
									"height": 139,
									"text": "Etape 13 : Scénario d'Erreur\nLa base de données ne répond pas dans le temps imparti\n11.1 Afficher un message d'erreur\n11.2. Arrêter le scénario\nDans le scénario nominal la base de donnée répond dans le temps imparti"
								},
								{
									"_type": "UMLNoteView",
									"_id": "AAAAAAGdKltCOab9+h4=",
									"_parent": {
										"$ref": "AAAAAAGdKjrtDaRJVIg="
									},
									"font": "Arial;13;0",
									"left": 992,
									"top": 1392,
									"width": 281,
									"height": 139,
									"text": "Etape 16 : Scénario d'Erreur\nLa base de données n'a pas pu annuler la commande\n16.1 Afficher un message d'erreur\n16.2. Rembourser l'Artiste\n16.3 Arrêter le scénario\nDans le scénario nominal la base de donnée confirme l'annulation de la commande"
								}
							]
						}
